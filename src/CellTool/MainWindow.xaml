<Window x:Class="CellTool.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Title="CellTool — NAND Vt Analyzer"
             Height="900" Width="1400"
             MinHeight="600" MinWidth="1000"
             WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource CellTool.TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource CellTool.BackgroundBrush}"
                BorderBrush="{DynamicResource CellTool.BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="16,0">
                <TextBlock Text="CellTool"
                           DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource CellTool.TextPrimaryBrush}" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="首页"
                            Style="{StaticResource NavButtonStyle}"
                            Click="HomeNav_Click" />
                    <Button Content="数据配置"
                            Style="{StaticResource NavButtonStyle}"
                            Click="DataConfigNav_Click" />
                    <Button Content="图表配置"
                            Style="{StaticResource NavButtonStyle}"
                            Click="ChartConfigNav_Click" />
                    <Button Content="自动化"
                            Style="{StaticResource NavButtonStyle}"
                            Click="AutomationNav_Click" />
                    <Button Content="设置"
                            Style="{StaticResource NavButtonStyle}"
                            Click="SettingsNav_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Frame x:Name="ContentFrame"
               Grid.Row="1"
               NavigationUIVisibility="Hidden" />
    </Grid>

</Window>
