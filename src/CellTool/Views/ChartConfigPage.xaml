<Page x:Class="CellTool.Views.ChartConfigPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:CellTool.ViewModels"
      xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance vm:ChartConfigViewModel}"
      Title="Chart Config">

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0">
            <StackPanel>
                <GroupBox Header="Labels" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <TextBlock Text="Title" Margin="0,0,0,2" />
                        <TextBox Text="{Binding ChartTitle, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <TextBlock Text="X Axis" Margin="0,0,0,2" />
                        <TextBox Text="{Binding XAxisLabel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <TextBlock Text="Y Axis" Margin="0,0,0,2" />
                        <TextBox Text="{Binding YAxisLabel, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Axis Range" Margin="0,0,0,8">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="X Min" VerticalAlignment="Center" />
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding XMin}" Margin="8,2,0,4" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="X Max" VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding XMax}" Margin="8,2,0,4" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Y Min" VerticalAlignment="Center" />
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding YMin}" Margin="8,2,0,4" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Y Max" VerticalAlignment="Center" />
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding YMax}" Margin="8,2,0,4" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="Annotations" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <CheckBox Content="Show 0.1% Boundary Lines"
                                  IsChecked="{Binding ShowBoundaryLines}" Margin="0,2" />
                        <CheckBox Content="Show Best Read Voltages"
                                  IsChecked="{Binding ShowReadVoltage}" Margin="0,2" />
                        <CheckBox Content="Show Legend"
                                  IsChecked="{Binding ShowLegend}" Margin="0,2" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Template" Margin="0,0,0,8">
                    <StackPanel Margin="8" Orientation="Horizontal">
                        <Button Content="Save" Width="70" Margin="0,0,4,0"
                                Command="{Binding SaveChartTemplateCommand}" />
                        <Button Content="Load" Width="70"
                                Command="{Binding LoadChartTemplateCommand}" />
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Column="1" Margin="12,0,0,0"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="6">
            <Grid Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                <sp:WpfPlot x:Name="ChartPlot"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            </Grid>
        </Border>
    </Grid>

</Page>
