<Page x:Class="CellTool.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:CellTool.ViewModels"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance vm:HomeViewModel}"
      Title="首页">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Section: Directories -->
        <GroupBox Grid.Row="0" Header="数据路径" Margin="0,0,0,12">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="输入目录:" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding InputDirectory, UpdateSourceTrigger=PropertyChanged}" Margin="4" />
                <Button Grid.Row="0" Grid.Column="2" Content="浏览..." Width="80"
                        Command="{Binding BrowseInputDirectoryCommand}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="输出目录:" VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}" Margin="4" />
                <Button Grid.Row="1" Grid.Column="2" Content="浏览..." Width="80"
                        Command="{Binding BrowseOutputDirectoryCommand}" />
            </Grid>
        </GroupBox>

        <!-- Section: Voltage & WL parameters -->
        <GroupBox Grid.Row="1" Header="扫描参数" Margin="0,0,0,12">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="最低档位:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox Grid.Column="1" Text="{Binding VoltageMin}" />

                <TextBlock Grid.Column="2" Text="最高档位:" VerticalAlignment="Center" Margin="8,0,4,0" />
                <TextBox Grid.Column="3" Text="{Binding VoltageMax}" />

                <TextBlock Grid.Column="4" Text="档位步长:" VerticalAlignment="Center" Margin="8,0,4,0" />
                <TextBox Grid.Column="5" Text="{Binding VoltageStep}" />

                <TextBlock Grid.Column="6" Text="WL 数量:" VerticalAlignment="Center" Margin="8,0,4,0" />
                <TextBox Grid.Column="7" Text="{Binding WlCount}" />

                <TextBlock Grid.Column="8" Text="起始页:" VerticalAlignment="Center" Margin="8,0,4,0" />
                <TextBox Grid.Column="9" Text="{Binding StartPage}" />
            </Grid>
        </GroupBox>

        <!-- Section: Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <ui:Button Content="开始分析"
                    Command="{Binding StartAnalysisCommand}"
                    IsEnabled="{Binding IsAnalyzing, Converter={StaticResource BooleanInvertConverter}}"
                    Appearance="Primary"
                    Width="140"
                    Margin="0,0,8,0" />
            <Button Content="取消"
                    Command="{Binding CancelAnalysisCommand}"
                    IsEnabled="{Binding IsAnalyzing}"
                    Width="80" />
        </StackPanel>

        <!-- Progress -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <ProgressBar Value="{Binding Progress}" Height="6" />
            <TextBlock Text="{Binding StatusMessage}" Margin="0,10,0,0" />
        </Grid>

        <!-- Log -->
        <GroupBox Grid.Row="4" Header="日志">
            <ListBox ItemsSource="{Binding LogEntries}" Margin="4"
                     FontFamily="Consolas" FontSize="12" />
        </GroupBox>
    </Grid>

</Page>
