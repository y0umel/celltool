<Application x:Class="CellTool.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:CellTool.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
            <converters:BooleanInvertConverter x:Key="BooleanInvertConverter" />
            <SolidColorBrush x:Key="CellTool.BackgroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="CellTool.SurfaceBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="CellTool.BorderBrush" Color="#DADADA" />
            <SolidColorBrush x:Key="CellTool.TextPrimaryBrush" Color="#1A1A1A" />
            <SolidColorBrush x:Key="CellTool.TextSecondaryBrush" Color="#5A5A5A" />
            <SolidColorBrush x:Key="CellTool.AccentBrush" Color="#138A74" />

            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource CellTool.TextPrimaryBrush}" />
            </Style>
            <Style TargetType="{x:Type GroupBox}">
                <Setter Property="Foreground" Value="{DynamicResource CellTool.TextPrimaryBrush}" />
            </Style>
            <Style TargetType="{x:Type CheckBox}">
                <Setter Property="Foreground" Value="{DynamicResource CellTool.TextPrimaryBrush}" />
            </Style>
            <Style TargetType="{x:Type ui:ToggleSwitch}">
                <Setter Property="Foreground" Value="{DynamicResource CellTool.TextPrimaryBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
